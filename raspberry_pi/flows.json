    {
        "id": "f07bd59c4c409f5a",
        "type": "function",
        "z": "6236dbe166d9dd7a",
        "name": "Split to Topics",
        "func": "var data = msg.payload;\n\nvar motion = {payload: data.MOTION, topic:\"infant/sensors/motion\"};\nvar temp = {payload: data.TEMP, topic: \"infant/sensors/temperature\"};\nvar humidity = {payload: data.HUMIDITY, topic: \"infant/sensors/humidity\"};\nvar light = {payload: data.LIGHT, topic: \"infant/sensors/light\"};\nvar loudness = { payload: data.LOUDNESS, topic: \"infant/sensors/loudness\"};\nvar rfid = {payload: data.RFID, topic: \"infant/sensors/rfid\"};\n\nreturn [motion, temp, humidity, light, loudness, rfid];",
