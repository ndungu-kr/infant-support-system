    {
        "id": "85ed207c2ccec6bb",
        "type": "function",
        "z": "6236dbe166d9dd7a",
        "name": "Format HTTP Telemetry",
        "func": "var data = msg.payload;\n\nmsg.payload = {\n    temperature: data.TEMP,\n    humidity: data.HUMIDITY,\n    light: data.LIGHT,\n    loudness: data.LOUDNESS,\n    motion: data.MOTION,\n    rfid: data.RFID\n};\n\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\n\nreturn msg;",
